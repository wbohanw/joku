{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir",
        "./browser-profile",
        "--output-dir",
        "./artifacts",
        "--browser",
        "chromium",
        "--save-session",
        "--headless"
      ]
    }
  }
}
