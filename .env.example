# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# From Lumee's Botpress dashboard (Settings → API Keys)
LUMEE_BOTPRESS_PAT=bp_pat_xxxxx

# lumeeBot's Bot ID (from the Botpress dashboard URL or agent.local.json)
LUMEE_BOT_ID=bot_xxxxx

# Your userId in Lumee's ResumeProfilesTable
# (visible in Lumee's profile page URL, or ask in Lumee chat: "what is my userId")
LUMEE_USER_ID=usr_xxxxx
